{
  "name": "@arts-and-crafts/v5-utils",
  "version": "5.0.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arts-n-crafts/typescript.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    "./core": {
      "import": {
        "types": "./dist/core/index.d.ts",
        "default": "./dist/core/index.js"
      },
      "require": {
        "types": "./dist/core/index.d.cts",
        "default": "./dist/core/index.cjs"
      }
    },
    "./adapters/inbound": {
      "import": {
        "types": "./dist/adapters-inbound/index.d.ts",
        "default": "./dist/adapters-inbound/index.js"
      },
      "require": {
        "types": "./dist/adapters-inbound/index.d.cts",
        "default": "./dist/adapters-inbound/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "lint": "oxlint src/",
    "lint:fix": "oxlint --fix src/",
    "fmt": "oxfmt src/",
    "fmt:check": "oxfmt --check src/",
    "test": "NODE_ENV=test vitest",
    "test:watch": "NODE_ENV=test vitest --coverage --watch",
    "test:ui": "NODE_ENV=test vitest --watch --coverage --ui",
    "coverage": "NODE_ENV=test vitest --coverage",
    "typecheck": "tsc --noEmit",
    "build": "rimraf dist && tsup"
  },
  "dependencies": {
    "@arts-and-crafts/v5": "workspace:*",
    "neverthrow": "^8.2.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@release-it/bumper": "^7.0.5",
    "@types/node": "^26.1.1",
    "@vitest/coverage-istanbul": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "changelogen": "^0.6.2",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.5",
    "zod": "^4.4.2"
  },
  "peerDependencies": {
    "typescript": "^6.0.3",
    "zod": "^4.4.2"
  }
}
